{
  "version": 2,
  "regions": ["sin1"],
  "builds": [
    { "src": "app.py", "use": "@vercel/python" }
  ],
  "headers": [
    {
      "source": "/static/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "app.py" }
  ]
}